rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      // Allow if the user's role in the /users collection is 'admin'
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow read, update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow delete: if isAdmin();
    }

    // --- Products Collection ---
    match /products/{productId} {
      // Anyone can read active products (also visible to admins regardless of status)
      allow read: if resource.data.active == true || isAdmin();
      allow write: if isAdmin();
    }

    // --- Categories Collection ---
    match /categories/{categoryId} {
      allow read: if resource.data.active == true || isAdmin();
      allow write: if isAdmin();
    }

    // --- Orders Collection ---
    match /orders/{orderId} {
      // Only authenticated users can read their own orders (and admins can read all)
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      // Only authenticated users can create an order, and they must assign it to themselves
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      // Only admins can update (or delete) any order
      allow update, delete: if isAdmin();
    }

    // --- Appointments Collection ---
    match /appointments/{appointmentId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      
      // Allow creation for authenticated users assigning to themselves.
      // Also allow creation for unauthenticated users (booking without an account).
      allow create: if isAuthenticated() ? request.resource.data.userId == request.auth.uid : true;
      allow update, delete: if isAdmin();
    }
  }
}
